#!/bin/bash
my_dir=$(dirname "$(realpath -s "$0")")
for last; do :; done
expected_args="-m pylint --ignore-paths /src/excluded_dir --exit-zero --output-format json2 $last"
if [ "$*" != "$expected_args" ]; then
  >&2 echo "expected: $expected_args"
  >&2 echo "received: $*"
  exit 1
fi
cat "$my_dir/../../manualScan.json"
